[Unit]
Description=phingr Web Server
After=network-online.target phingr-touch.service
Wants=network-online.target
Requires=phingr-touch.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/phingr/web_server.py --port 8080 --cam-width 1920 --cam-height 1080
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
